PORT=8090

# LAN subnet allowed to access /config and /downloads (CIDR notation)
# Example: 192.168.1.0/24 or 10.0.0.0/8
ALLOWED_CIDR=192.168.1.0/24

QBITTORRENT_URL=http://localhost:8080
QBITTORRENT_USER=admin
QBITTORRENT_PASS=changeme

# Comma-separated list of allowed save paths.
# Only these paths can be selected in the UI or submitted via the API.
# Each path must be absolute and must exist on disk.
QBITTORRENT_SAVE_PATHS=/downloads,/media/music,/media/video

# Absolute path to the `ia` CLI binary.
# Leave empty to auto-detect via PATH at startup.
IA_BIN=

# Show cover images on audio detail pages (true/false)
SHOW_COVERS=false
